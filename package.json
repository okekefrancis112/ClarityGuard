{
  "name": "clarityguard",
  "version": "0.1.0",
  "description": "Security scanner for Clarity smart contracts on Stacks",
  "main": "dist/index.js",
  "bin": {
    "clarityguard": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "clarity",
    "stacks",
    "security",
    "smart-contract",
    "scanner",
    "audit"
  ],
  "author": "Okeke Francis Chukwudalu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/okekefrancis112/ClarityGuard.git"
  },
  "bugs": {
    "url": "https://github.com/okekefrancis112/ClarityGuard/issues"
  },
  "homepage": "https://github.com/okekefrancis112/ClarityGuard#readme",
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@vitest/coverage-v8": "^4.0.18",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
